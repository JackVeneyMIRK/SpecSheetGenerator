.columns {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 0.18in;
  padding: 0.09in 0.38in 0.07in;
  overflow: hidden;
}

.col-left,
.col-right {
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 0.1in;
  overflow: hidden;
}

.col-left { flex: 1; }
.col-right { flex: 1.15; }

.sec { flex-shrink: 0; }

.sec-hd {
  font-size: 7.8pt;
  font-weight: 700;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 0.07em;
  border-bottom: 1.5px solid var(--section-rule);
  padding-bottom: 2px;
  margin-bottom: 3px;
}

.sec ul {
  list-style-type: none;
  margin: 0;
  padding-left: 12px;
}

.sec ul li {
  font-size: 6.6pt;
  line-height: 1.5;
  color: #1a1a1a;
  padding-left: 0;
}

.sec ul li::marker {
  content: '▸  ';
  color: var(--primary);
  font-size: 0.9em;
  font-family: "Segoe UI Symbol", "Segoe UI", sans-serif;
}

.photo {
  border: 1px solid rgba(0, 0, 0, 0.28);
  border-radius: 3px;
  overflow: hidden;
  background: var(--photo-bg);
  min-height: 1.1in;
  flex: 1 1 0;
}

.photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.photo-hero {
  flex: 1.1 1 0;
  min-height: 1.7in;
  max-height: 2.35in;
}

.photo-small {
  flex: 1.35 1 0;
  min-height: 1.5in;
  max-height: 2.65in;
}
