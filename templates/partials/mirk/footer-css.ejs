.foot {
  background: var(--primary);
  padding: 0;
  flex-shrink: 0;
}

.foot-text {
  padding: 7px 0.38in 8px;
  text-align: center;
}

.foot-text span {
  display: block;
  color: rgba(255,255,255,0.92);
  font-size: 7.2pt;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  line-height: 1.55;
}
