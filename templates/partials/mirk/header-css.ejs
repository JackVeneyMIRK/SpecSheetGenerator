.hdr {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.16in 0 0.16in 0.125in;
  border-bottom: 1px solid #d0d8d0;
  flex-shrink: 0;
  min-height: 1.1in;
}

.hdr-logo img {
  height: 0.82in;
  width: auto;
  display: block;
}

.hdr-logo span {
  font-size: 28pt;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.02em;
}

.hdr-right {
  text-align: right;
  padding-right: 0.125in;
}

.hdr-phone {
  font-size: 20pt;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -0.02em;
  line-height: 1;
}

.hdr-detail {
  font-size: 7.5pt;
  color: #444;
  margin-top: 4px;
  line-height: 1.5;
}

.tagline {
  background: var(--primary);
  padding: 7px 0.38in 8px;
  flex-shrink: 0;
  text-align: center;
}

.tagline span {
  color: rgba(255,255,255,0.95);
  font-size: 7.5pt;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
