.hdr-image {
  flex-shrink: 0;
  line-height: 0;
}

.hdr-image img {
  width: 100%;
  height: auto;
  display: block;
}

.hdr {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.16in 0 0.16in 0.125in;
  flex-shrink: 0;
  min-height: 1.1in;
}

.hdr-logo img {
  height: 0.78in;
  width: auto;
  display: block;
}

.hdr-logo span {
  font-size: 26pt;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.02em;
}

.hdr-center {
  flex: 1;
  text-align: left;
  padding: 0 0.3in 0 0.75in;
}

.hdr-company {
  font-size: 20pt;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -0.01em;
  line-height: 1;
}

.hdr-right {
  display: grid;
  justify-items: end;
  align-content: center;
  row-gap: 5px;
  text-align: right;
  padding-right: 0.125in;
}

.hdr-phone {
  font-size: 20pt;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -0.02em;
  line-height: 1;
}

.hdr-detail {
  font-size: 8.5pt;
  color: #444;
  margin-top: 0;
  line-height: 1.35;
}

.hdr-phone + .hdr-detail {
  margin-top: 4px;
}

.accent {
  background: var(--accent);
  height: 5px;
  flex-shrink: 0;
}

.tagline {
  background: var(--primary);
  padding: 7px 0.38in 8px;
  flex-shrink: 0;
  text-align: center;
}

.tagline span {
  color: rgba(255,255,255,0.95);
  font-size: 7.5pt;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.hdr-sep {
  display: inline-block;
  margin: 0 0.26em;
}

.hdr-link {
  color: inherit;
  text-decoration: none;
}
