.hdr-image {
  flex-shrink: 0;
  line-height: 0;
}

.hdr-image img {
  width: 100%;
  height: auto;
  display: block;
}

.hdr {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.16in 0 0.16in 0.125in;
  flex-shrink: 0;
  min-height: 1.1in;
}

.hdr-logo img {
  height: 0.78in;
  width: auto;
  display: block;
}

.hdr-logo span {
  font-size: 26pt;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.02em;
}

.hdr-center {
  flex: 1;
  text-align: center;
  padding: 0 0.3in;
}

.hdr-company {
  font-size: 20pt;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -0.01em;
  line-height: 1;
}

.hdr-right {
  text-align: right;
  padding-right: 0.125in;
}

.hdr-phone {
  font-size: 14pt;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: -0.01em;
  line-height: 1;
}

.hdr-detail {
  font-size: 7.5pt;
  color: #444;
  margin-top: 4px;
  line-height: 1.5;
}

.accent {
  background: var(--accent);
  height: 5px;
  flex-shrink: 0;
}

.tagline {
  background: var(--primary);
  padding: 7px 0.38in 8px;
  flex-shrink: 0;
  text-align: center;
}

.tagline span {
  color: rgba(255,255,255,0.95);
  font-size: 7.5pt;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
