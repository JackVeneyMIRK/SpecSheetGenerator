<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>#<%= unit.unit %> – Spec Sheet</title>
<style>
  :root {
    --primary: <%= brand.primary %>;
    --accent:  <%= brand.accent %>;
  }

  *, *::before, *::after {
    margin: 0; padding: 0; box-sizing: border-box;
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }

  /* Margins live here — Chromium's print engine applies them evenly on all 4 sides */
  @page { size: letter portrait; margin: 0.25in; }

  html, body {
    width: 8in; height: 10.5in;
    font-family: 'Segoe UI', system-ui, -apple-system, Arial, sans-serif;
    background: #fff;
    color: #1a1a1a;
  }

  .page {
    /* Content area after @page margins: 8in × 10.5in */
    width: 8in; height: 10.5in;
    display: flex; flex-direction: column;
    overflow: hidden;
  }

  /* ── Header image (full-width SVG letterhead) ───────────────── */
  .hdr-image {
    flex-shrink: 0;
    line-height: 0;
  }

  .hdr-image img {
    width: 100%; height: auto; display: block;
  }

  /* ── Header (white, tall — matching letterhead) ──────────────── */
  .hdr {
    background: #fff;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.16in 0 0.16in 0.125in;
    flex-shrink: 0;
    min-height: 1.1in;
  }

  .hdr-logo img {
    height: 0.78in; width: auto; display: block;
  }

  .hdr-logo span {
    font-size: 26pt; font-weight: 800; color: var(--primary); letter-spacing: -0.02em;
  }

  .hdr-center {
    flex: 1;
    text-align: center;
    padding: 0 0.3in;
  }

  .hdr-company {
    font-size: 20pt; font-weight: 700;
    color: var(--primary); letter-spacing: -0.01em; line-height: 1;
  }

  .hdr-right { text-align: right; padding-right: 0.125in; }

  .hdr-phone {
    font-size: 14pt; font-weight: 700;
    color: var(--primary); letter-spacing: -0.01em; line-height: 1;
  }

  .hdr-detail {
    font-size: 7.5pt; color: #444;
    margin-top: 4px; line-height: 1.5;
  }

  /* ── Gold accent bar ─────────────────────────────────────────── */
  .accent {
    background: var(--accent);
    height: 5px;
    flex-shrink: 0;
  }

  /* ── Navy tagline bar ────────────────────────────────────────── */
  .tagline {
    background: var(--primary);
    padding: 7px 0.38in 8px;
    flex-shrink: 0;
    text-align: center;
  }

  .tagline span {
    color: rgba(255,255,255,0.95);
    font-size: 7.5pt; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
  }

  /* ── Unit title ─────────────────────────────────────────────── */
  .unit-hdr {
    padding: 0.08in 0.38in 0.065in;
    display: flex; align-items: baseline; gap: 0.12in;
    border-bottom: 2.5px solid var(--accent);
    flex-shrink: 0;
  }

  .unit-num {
    font-size: 19pt; font-weight: 800;
    color: var(--primary); letter-spacing: -0.02em; line-height: 1;
  }

  .unit-lbl {
    font-size: 14pt; font-weight: 700; color: #555; line-height: 1;
  }

  /* ── Two-column staggered content ────────────────────────────── */
  .columns {
    flex: 1; min-height: 0;
    display: flex; gap: 0.18in;
    padding: 0.09in 0.38in 0.07in;
    overflow: hidden;
  }

  .col-left {
    flex: 1;
    min-height: 0;
    display: flex; flex-direction: column; gap: 0.1in;
  }

  .col-right {
    flex: 1.15;
    min-height: 0;
    display: flex; flex-direction: column; gap: 0.1in;
    overflow: hidden;
  }

  .sec { flex-shrink: 0; }

  .sec-hd {
    font-size: 6.8pt; font-weight: 700;
    color: var(--primary); text-transform: uppercase;
    letter-spacing: 0.07em;
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px; margin-bottom: 3px;
  }

  .sec ul { list-style: none; }

  .sec ul li {
    font-size: 6.6pt; line-height: 1.5;
    color: #1a1a1a;
    padding-left: 8px; position: relative;
  }

  .sec ul li::before {
    content: '▸';
    position: absolute; left: 0; top: 0.5px;
    color: var(--primary); font-size: 4.8pt; line-height: 1.65;
  }

  .photo {
    border-radius: 3px; overflow: hidden;
    background: #e8e8ee;
    min-height: 0;
  }

  .photo img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block;
  }

  .photo-hero  { height: 2.5in; flex-shrink: 0; }
  .photo-small { height: 1.55in; flex-shrink: 0; }

  /* ── Footer ─────────────────────────────────────────────────── */
  .foot {
    background: var(--primary);
    padding: 0;
    flex-shrink: 0;
  }

  .foot-gold { background: var(--accent); height: 4px; }

  .foot-text {
    padding: 7px 0.38in 8px;
    text-align: center;
  }

  .foot-text span {
    display: block;
    color: rgba(255,255,255,0.95);
    font-size: 7.5pt; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    line-height: 1.6;
  }

  .foot-text-2 {
    color: rgba(255,255,255,0.95) !important;
    font-size: 7.5pt !important; font-weight: 700 !important;
    letter-spacing: 0.1em !important;
  }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <% if (headerImageUri) { %>
  <header class="hdr-image">
    <img src="<%= headerImageUri %>" alt="<%= company.name %>">
  </header>
  <% } else { %>
  <header class="hdr">
    <div class="hdr-logo">
      <% if (logoUri) { %>
      <img src="<%= logoUri %>" alt="<%= company.name %>">
      <% } else { %>
      <span>PLREI</span>
      <% } %>
    </div>
    <div class="hdr-center">
      <div class="hdr-company"><%= company.name %></div>
    </div>
    <div class="hdr-right">
      <% if (company.phone) { %>
      <div class="hdr-phone"><%= company.phone %></div>
      <% } %>
      <% if (company.address || company.city) { %>
      <div class="hdr-detail">
        <%= company.address %>
        <% if (company.city) { %>&nbsp; | &nbsp;<%= company.city %><% } %>
      </div>
      <% } %>
      <div class="hdr-detail">
        <%= company.website %>
        <% if (company.email) { %>&nbsp; | &nbsp;<%= company.email %><% } %>
      </div>
    </div>
  </header>
  <!-- Gold accent line + navy tagline -->
  <div class="accent"></div>
  <div class="tagline"><span><%= company.tagline %></span></div>
  <% } %>

  <!-- Unit title -->
  <div class="unit-hdr">
    <span class="unit-num">#<%= unit.unit %></span>
    <% if (unit.title) { %><span class="unit-lbl"><%= unit.title %></span><% } %>
  </div>

  <div class="columns">

    <!-- Left col: even sections + odd photos (1, 3, ...) -->
    <div class="col-left">
      <% unit.sections.forEach((s, i) => { %>
      <% if (i % 2 === 0) { %>
      <div class="sec">
        <div class="sec-hd"><%= s.heading %></div>
        <ul>
          <% s.items.forEach(item => { %><li><%= item %></li><% }) %>
        </ul>
      </div>
      <% if (photos[i + 1]) { %>
      <div class="photo photo-small">
        <img src="<%= photos[i + 1].dataUri %>" alt="" style="object-position: <%= photos[i + 1].focalX %>% <%= photos[i + 1].focalY %>%">
      </div>
      <% } %>
      <% } %>
      <% }) %>
    </div>

    <!-- Right col: photo[0] first, then odd sections + even photos (2, 4, ...) -->
    <div class="col-right">
      <% if (photos[0]) { %>
      <div class="photo photo-hero">
        <img src="<%= photos[0].dataUri %>" alt="" style="object-position: <%= photos[0].focalX %>% <%= photos[0].focalY %>%">
      </div>
      <% } %>
      <% unit.sections.forEach((s, i) => { %>
      <% if (i % 2 === 1) { %>
      <div class="sec">
        <div class="sec-hd"><%= s.heading %></div>
        <ul>
          <% s.items.forEach(item => { %><li><%= item %></li><% }) %>
        </ul>
      </div>
      <% if (photos[i + 1]) { %>
      <div class="photo photo-small">
        <img src="<%= photos[i + 1].dataUri %>" alt="" style="object-position: <%= photos[i + 1].focalX %>% <%= photos[i + 1].focalY %>%">
      </div>
      <% } %>
      <% } %>
      <% }) %>
    </div>

  </div>

  <!-- Footer -->
  <footer class="foot">
    <div class="foot-gold"></div>
    <div class="foot-text">
      <span><%= company.footer_cta %></span>
      <% if (company.footer_cta2) { %>
      <span class="foot-text-2"><%= company.footer_cta2 %></span>
      <% } %>
    </div>
  </footer>

</div>
</body>
</html>
